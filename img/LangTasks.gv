digraph LangProf {

  subgraph {
    rank="source"  
    Reading; Listening
  }
  subgraph {
    rank="same"
    Writing, Speaking
  }

  subgraph {
    rank="sink"
    TaskA
    TaskB
    TaskC
    TaskD
  }
  
  Reading -> Writing 
  Listening -> Speaking 
  Reading -> Listening 
  Writing -> Speaking 

  Reading -> TaskA
  Reading -> TaskB; Writing -> TaskB
  Listening -> TaskC; Reading->TaskC; Speaking -> TaskC
  Listening -> TaskD
}